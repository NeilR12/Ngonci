# Copy this file to .env and fill in the values.
# Use .env (not .env.local) so the Prisma CLI can read DATABASE_URL too.
# These are only needed if you turn on cloud sync. Local-only mode needs nothing.

# Neon Postgres connection string (Settings -> Connection details in the Neon console)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# A long random string for signing session tokens.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"

# The app's URL. Use http://localhost:3000 locally; your real URL on Vercel.
NEXTAUTH_URL="http://localhost:3000"
